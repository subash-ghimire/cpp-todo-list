#include <iostream>
#include <vector>
#include <fstream>

using namespace std;

// Function to load tasks from file
void loadTasks(vector<string>& tasks) {
    ifstream file("tasks.txt");
    string task;

    while (getline(file, task)) {
        tasks.push_back(task);
    }

    file.close();
}

// Function to save tasks to file
void saveTasks(vector<string>& tasks) {
    ofstream file("tasks.txt");

    for (int i = 0; i < tasks.size(); i++) {
        file << tasks[i] << endl;
    }

    file.close();
}

int main() {
    vector<string> tasks;
    int choice;

    // Load existing tasks when program starts
    loadTasks(tasks);

    do {
        cout << "\n==== TO-DO LIST MENU ====\n";
        cout << "1. Add Task\n";
        cout << "2. View Tasks\n";
        cout << "3. Delete Task\n";
        cout << "4. Mark Task as Completed\n";
        cout << "5. Exit\n";
        cout << "Choose an option: ";
        cin >> choice;
        cin.ignore();  // Clear newline from input buffer

        switch (choice) {

            case 1: {
                string newTask;
                cout << "Enter new task: ";
                getline(cin, newTask);
                tasks.push_back("[ ] " + newTask);
                saveTasks(tasks);
                cout << "Task added successfully!\n";
                break;
            }

            case 2: {
                cout << "\nYour Tasks:\n";
                if (tasks.empty()) {
                    cout << "No tasks available.\n";
                } else {
                    for (int i = 0; i < tasks.size(); i++) {
                        cout << i + 1 << ". " << tasks[i] << endl;
                    }
                }
                break;
            }

            case 3: {
                int taskNumber;
                cout << "Enter task number to delete: ";
                cin >> taskNumber;

                if (taskNumber > 0 && taskNumber <= tasks.size()) {
                    tasks.erase(tasks.begin() + taskNumber - 1);
                    saveTasks(tasks);
                    cout << "Task deleted successfully!\n";
                } else {
                    cout << "Invalid task number.\n";
                }
                break;
            }

            case 4: {
                int taskNumber;
                cout << "Enter task number to mark as completed: ";
                cin >> taskNumber;

                if (taskNumber > 0 && taskNumber <= tasks.size()) {
                    if (tasks[taskNumber - 1].substr(0, 3) == "[ ]") {
                        tasks[taskNumber - 1].replace(0, 3, "[X]");
                        saveTasks(tasks);
                        cout << "Task marked as completed!\n";
                    } else {
                        cout << "Task already completed.\n";
                    }
                } else {
                    cout << "Invalid task number.\n";
                }
                break;
            }

            case 5:
                cout << "Exiting program...\n";
                break;

            default:
                cout << "Invalid option. Try again.\n";
        }

    } while (choice != 5);

    return 0;
}